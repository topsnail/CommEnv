{
  "name": "commenv",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "dev:pages": "npm run build && wrangler pages dev --port 8787",
    "dev:pages:restart": "wrangler pages dev --port 8787 --force",
    "dev:all": "concurrently -k \"npm run dev:pages\" \"npm run dev\"",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs --fix --ignore-path .gitignore",
    "format": "prettier --write src/",
    "backfill:derivatives": "node scripts/backfill-derivatives.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1018.0",
    "archiver": "^7.0.1",
    "axios": "^1.6.8",
    "bcryptjs": "^3.0.3",
    "chart.js": "^4.5.1",
    "exceljs": "^4.4.0",
    "exifr": "^7.1.3",
    "pinia": "^2.1.7",
    "vue": "^3.4.21",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vue/tsconfig": "^0.9.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.22.0",
    "postcss": "^8.4.35",
    "prettier": "^3.2.5",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.1",
    "terser": "^5.46.1",
    "typescript": "^6.0.2",
    "vite": "^5.2.0"
  }
}
